    static constexpr auto major = @ufps_VERSION_MAJOR@;
    static constexpr auto minor = @ufps_VERSION_MINOR@;
    static constexpr auto patch = @ufps_VERSION_PATCH@;
    // clang-format on

}

namespace ufps::config
{
    // clang-format off
    static constexpr auto log_to_file = ${LOG_TO_FILE};
    static constexpr auto log_enable_debug = ${LOG_ENABLE_DEBUG};
    static constexpr auto opengl_debug_enabled = true;
    static constexpr bool use_embedded_resource_loader = UFPS_USE_EMBEDDED_RESOURCE_LOADER;
    // clang-format on
}