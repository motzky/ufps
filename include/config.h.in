#pragma once

#cmakedefine01 UFPS_USE_EMBEDDED_RESOURCE_LOADER

namespace ufps::version
{
    // clang-format off
    static constexpr auto year = @ufps_VERSION_MAJOR@;
    static constexpr auto month = @ufps_VERSION_MINOR@;
    static constexpr auto day = @ufps_VERSION_PATCH@;
    static constexpr auto tweak = @ufps_VERSION_TWEAK@;
    // clang-format on

}

namespace ufps::config
{
    // clang-format off
    static constexpr auto log_to_file = ${LOG_TO_FILE};
    static constexpr auto log_enable_debug = ${LOG_ENABLE_DEBUG};
    static constexpr auto log_assimp = ${LOG_ASSIMP};
    static constexpr auto opengl_debug_enabled = ${OPENGL_ENABLE_DEBUG};
    static constexpr bool use_embedded_resource_loader = UFPS_USE_EMBEDDED_RESOURCE_LOADER;
    // clang-format on
}